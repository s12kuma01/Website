---
import { GITHUB_URL, DISCORD_URL, SITE_NAME, COPYRIGHT_YEAR } from '@/consts';
import { useDict, type Locale } from '@/i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useDict(locale);
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__social">
    <a class="footer__icon" href={GITHUB_URL} aria-label={t.footer.github} rel="me noopener" target="_blank">
      <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
        <path
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
        ></path>
      </svg>
    </a>
    <a class="footer__icon" href={DISCORD_URL} aria-label={t.footer.discord} rel="me noopener" target="_blank">
      <svg viewBox="0 0 127.14 96.36" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path
          d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"
        ></path>
      </svg>
    </a>
  </div>
    <div class="footer__meta">
      <span class="footer__line label-sm">© {COPYRIGHT_YEAR} {SITE_NAME}</span>
      <span class="footer__line label-sm">{t.footer.hosted}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 56px;
    padding: 14px 24px 18px;
    border-top: 1px solid color-mix(in srgb, var(--md-sys-color-outline-variant) 40%, transparent);
    background: transparent;
    color: var(--md-sys-color-on-surface-variant);
  }

  .footer__inner {
    max-width: 1200px;
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px 16px;
  }

  @media (min-width: 600px) {
    .footer__inner {
      justify-content: space-between;
    }
  }

  .footer__meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px 10px;
  }

  .footer__social {
    display: flex;
    gap: 4px;
  }

  .footer__icon {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: var(--md-sys-shape-corner-full);
    color: var(--md-sys-color-on-surface-variant);
    transition:
      background-color var(--md-sys-motion-spring-fast-effects-duration)
        var(--md-sys-motion-spring-fast-effects-easing),
      color var(--md-sys-motion-spring-fast-effects-duration)
        var(--md-sys-motion-spring-fast-effects-easing);
  }

  .footer__icon:hover {
    background: color-mix(
      in srgb,
      var(--md-sys-color-on-surface-variant) calc(var(--md-sys-state-hover) * 100%),
      transparent
    );
    color: var(--md-sys-color-on-surface);
  }

  .footer__icon:active {
    background: color-mix(
      in srgb,
      var(--md-sys-color-on-surface-variant) calc(var(--md-sys-state-press) * 100%),
      transparent
    );
  }

  .footer__line {
    margin: 0;
  }
</style>
