---
// The floating island header — a single M3E floating-toolbar pill (64px,
// translucent surface-container + blur). Composition uses sanctioned M3E parts only
// (toolbar + toggle-style nav links + a FAB menu for settings); no separate
// navigation bar exists on the site.
import SettingsFab from '@/components/SettingsFab.astro';
import ShapeMask from '@/components/ShapeMask.astro';
import { SITE_NAME } from '@/consts';
import { useDict, type Locale } from '@/i18n/ui';
import { localePath, stripLocale } from '@/i18n/routes';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useDict(locale);
const { path: currentPath } = stripLocale(Astro.url.pathname);

// Nav labels are fixed English on every locale (brand choice).
const tabs = [
  { key: 'home', path: '/', label: 'Home' },
  { key: 'projects', path: '/projects', label: 'Projects' },
  { key: 'about', path: '/about', label: 'About' },
] as const;

const normalize = (p: string) => (p.endsWith('/') && p !== '/' ? p.slice(0, -1) : p);
const isActive = (tabPath: string) => normalize(currentPath) === normalize(tabPath);

const icons: Record<string, string> = {
  home: 'M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z',
  projects:
    'M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z',
  about:
    'M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z',
};
---

<header class="island" data-state="expanded">
  <div class="island__wrap">
    <nav class="island__pill" aria-label={t.nav.primary}>
      <a class="island__brand" href={localePath(locale, '/')} aria-label={SITE_NAME}>
        <ShapeMask shape="cookie7" class="island__badge-mask">
          <img
            class="island__badge-img"
            src="/mascot.png"
            alt=""
            width="128"
            height="128"
          />
        </ShapeMask>
      </a>
      <div class="island__tabs">
        {
          tabs.map((tab) => (
            <a
              class="island__tab"
              href={localePath(locale, tab.path)}
              aria-current={isActive(tab.path) ? 'page' : undefined}
            >
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={icons[tab.key]} />
              </svg>
              <span class="island__tab-label">{tab.label}</span>
            </a>
          ))
        }
      </div>
      <div class="island__utils">
        <SettingsFab locale={locale} path={currentPath} />
      </div>
    </nav>
  </div>
</header>

<script>
  import '@/scripts/header.ts';
</script>

<style>
  .island {
    --_h: 64px;
    --_r: calc(var(--_h) / 2);
    position: fixed;
    top: 12px;
    inset-inline: 16px;
    z-index: 100;
    display: flex;
    justify-content: center;
    pointer-events: none;
    transition: translate var(--md-sys-motion-spring-fast-spatial-duration)
      var(--md-sys-motion-spring-fast-spatial-easing);
  }

  .island[data-state='hidden'] {
    translate: 0 calc(-100% - 16px);
  }

  .island__wrap {
    position: relative;
    width: min(720px, 100%);
    pointer-events: auto;
  }

  .island__pill {
    display: flex;
    align-items: center;
    gap: 4px;
    height: var(--_h);
    padding: 8px;
    border-radius: var(--_r);
    background: color-mix(in srgb, var(--md-sys-color-surface-container) 42%, transparent);
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    transition:
      height var(--md-sys-motion-spring-default-spatial-duration)
        var(--md-sys-motion-spring-default-spatial-easing),
      border-radius var(--md-sys-motion-spring-default-spatial-duration)
        var(--md-sys-motion-spring-default-spatial-easing);
  }

  /* Keep nav text readable if backdrop blur is unavailable — raise opacity. */
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .island__pill {
      background: color-mix(in srgb, var(--md-sys-color-surface-container) 88%, transparent);
    }
  }

  .island[data-state='condensed'] {
    --_h: 56px;
    --_r: 28px;
  }

  .island__brand {
    display: flex;
    align-items: center;
    padding: 2px;
    border-radius: 24px;
    text-decoration: none;
  }

  .island :global(.island__badge-mask) {
    width: 38px;
    height: 38px;
    flex: none;
    /* Light backing so the black line-art mascot stays legible in both colour
       modes; a whisper of the theme's primary tints it. */
    background: color-mix(in srgb, var(--md-sys-color-primary-container) 22%, white);
  }

  .island__badge-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 2px;
  }

  .island__tabs {
    position: relative;
    display: flex;
    align-items: center;
    gap: 4px;
    margin-inline: auto;
    min-width: 0;
  }

  .island__tab {
    display: flex;
    align-items: center;
    gap: 6px;
    height: 40px;
    padding-inline: 16px;
    border-radius: 20px;
    position: relative;
    z-index: 1;
    overflow: hidden; /* clips the ripple to the pill shape */
    color: var(--md-sys-color-on-surface-variant);
    text-decoration: none;
    white-space: nowrap;
    font-size: var(--md-sys-typescale-label-lg-size);
    line-height: var(--md-sys-typescale-label-lg-line-height);
    font-weight: var(--md-sys-typescale-weight-medium);
    transition: color var(--md-sys-motion-spring-fast-effects-duration)
      var(--md-sys-motion-spring-fast-effects-easing);
  }

  .island__tab svg {
    width: 20px;
    height: 20px;
    flex: none;
  }

  .island__tab[aria-current='page'] {
    color: var(--md-sys-color-on-secondary-container);
    font-weight: var(--md-sys-typescale-weight-medium-emphasized);
  }

  /* Active indicator = a solid pill behind the label. Instead of sliding
     between tabs (which felt "しつこい"), selection is tap-to-fill like the
     M3 connected-button-group: a ripple from the pointer (ripple.ts) plus the
     pill springing in on the destination page. */
  .island__tab[aria-current='page']::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: 20px;
    background: var(--md-sys-color-secondary-container);
  }

  @media (prefers-reduced-motion: no-preference) {
    .island__tab[aria-current='page']::before {
      animation: tab-fill var(--md-sys-motion-spring-default-spatial-duration)
        var(--md-sys-motion-spring-default-spatial-easing) both;
      transform-origin: center;
    }
  }

  @keyframes tab-fill {
    from {
      opacity: 0;
      transform: scale(0.8);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .island__utils {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  /* Mobile: tabs go icon+stacked-label, then icon-only. */
  @media (max-width: 479px) {
    .island__tab {
      flex-direction: column;
      gap: 0;
      padding-inline: 10px;
      font-size: var(--md-sys-typescale-label-sm-size);
      line-height: 14px;
    }

    .island__tab svg {
      width: 18px;
      height: 18px;
    }
  }

  @media (max-width: 359px) {
    .island__tab-label {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }

    .island__tab {
      flex-direction: row;
      padding-inline: 12px;
    }

    .island__tab svg {
      width: 22px;
      height: 22px;
    }
  }
</style>
